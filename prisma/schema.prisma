// Schema Prisma — Parking Intelligent (Phase 1 minimum vital)
// Modèles auth/réservations/paiement viendront en Phase 6.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ParkingSpot {
  id            Int           @id
  name          String
  isOccupied    Boolean       @default(false)
  lastUpdatedAt DateTime      @default(now()) @updatedAt
  isActive      Boolean       @default(true)
  sensorData    SensorData[]
  reservations  Reservation[]
}

model Reservation {
  id              Int         @id @default(autoincrement())
  spotId          Int
  spot            ParkingSpot @relation(fields: [spotId], references: [id])
  licensePlate    String
  startTime       DateTime    @default(now())
  endTime         DateTime
  durationMinutes Int
  amountPaid      Float
  fineAmount      Float       @default(0)
  status          String      @default("ACTIVE") // ACTIVE | EXPIRED | COMPLETED | CANCELLED
  createdAt       DateTime    @default(now())

  @@index([spotId, status])
  @@index([licensePlate])
}

model SensorData {
  id         Int         @id @default(autoincrement())
  spotId     Int
  spot       ParkingSpot @relation(fields: [spotId], references: [id])
  isOccupied Boolean
  distanceCm Float
  esp32Id    String
  recordedAt DateTime    @default(now())

  @@index([spotId, recordedAt])
}
